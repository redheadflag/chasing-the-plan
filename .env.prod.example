# Copy to .env.prod and fill in real values (never commit .env.prod).
POSTGRES_USER=ctp
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=chasing_the_plan

# Localhost port the backend is published on for your host nginx to proxy to.
BACKEND_PORT=8000

# Leave empty when host nginx serves the SPA and proxies /api under one domain
# (same-origin). Set to your site origin only if the SPA is served elsewhere,
# e.g. CORS_ORIGINS=https://your.domain
CORS_ORIGINS=
